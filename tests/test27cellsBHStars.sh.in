#!/bin/bash

# List each test that should be run
declare -a TEST_LIST=(test27cellsBHStars test27cellsBHStars_subset)

# Run same test for each executable
for TEST in "${TEST_LIST[@]}"
do
  # Test with regular distributions and identical search radii
    echo ""

    rm -f bh_stars_brute_force_27_standard.dat swift_bh_stars_dopair_27_standard.dat

    echo "Running ./$TEST -N 7 -B 2 -r 1 -d 0 -f standard"
    ./$TEST -N 7 -B 2 -r 1 -d 0 -f standard

    if [ -e bh_stars_brute_force_27_standard.dat ]
    then
      if python3 @srcdir@/difffloat.py bh_stars_brute_force_27_standard.dat swift_bh_stars_dopair_27_standard.dat @srcdir@/bh_stars_tolerance_27.dat 2
      then
        echo "Accuracy test passed"
      else
        echo "Accuracy test failed"
        exit 1
      fi
    else
      echo "Error Missing test output file"
      exit 1
    fi

    echo "------------"

  # Test with random search radii
    echo ""

    rm -f bh_stars_brute_force_27_standard.dat swift_bh_stars_dopair_27_standard.dat

    echo "Running ./$TEST -N 7 -B 2 -r 1 -d 0 -f standard -p 1.3"
    ./$TEST -N 7 -B 2 -r 1 -d 0 -f standard -p 1.3

    if [ -e bh_stars_brute_force_27_standard.dat ]
    then
      if python3 @srcdir@/difffloat.py bh_stars_brute_force_27_standard.dat swift_bh_stars_dopair_27_standard.dat @srcdir@/bh_stars_tolerance_27.dat 2
      then
        echo "Accuracy test passed"
      else
        echo "Accuracy test failed"
        exit 1
      fi
    else
      echo "Error Missing test output file"
      exit 1
    fi

    echo "------------"

  # Test with perturbed particle positions
    echo ""

    rm -f bh_stars_brute_force_27_perturbed.dat swift_bh_stars_dopair_27_perturbed.dat

    echo "Running ./$TEST -N 7 -B 2 -r 1 -d 0.1 -f perturbed"
    ./$TEST -N 7 -B 2 -r 1 -d 0.1 -f perturbed

    if [ -e bh_stars_brute_force_27_perturbed.dat ]
    then
      if python3 @srcdir@/difffloat.py bh_stars_brute_force_27_perturbed.dat swift_bh_stars_dopair_27_perturbed.dat @srcdir@/bh_stars_tolerance_27.dat 2
      then
        echo "Accuracy test passed"
      else
        echo "Accuracy test failed"
        exit 1
      fi
    else
      echo "Error Missing test output file"
      exit 1
    fi

    echo "------------"

  # Test with perturbed positions and random search radii
    echo ""

    rm -f bh_stars_brute_force_27_perturbed.dat swift_bh_stars_dopair_27_perturbed.dat

    echo "Running ./$TEST -N 7 -B 2 -r 1 -d 0.1 -f perturbed -p 1.3"
    ./$TEST -N 7 -B 2 -r 1 -d 0.1 -f perturbed -p 1.3

    if [ -e bh_stars_brute_force_27_perturbed.dat ]
    then
      if python3 @srcdir@/difffloat.py bh_stars_brute_force_27_perturbed.dat swift_bh_stars_dopair_27_perturbed.dat @srcdir@/bh_stars_tolerance_27.dat 2
      then
        echo "Accuracy test passed"
      else
        echo "Accuracy test failed"
        exit 1
      fi
    else
      echo "Error Missing test output file"
      exit 1
    fi

    echo "------------"

done

exit $?
